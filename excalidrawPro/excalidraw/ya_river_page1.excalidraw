      "updated": 1784099688372,
      "link": null,
      "locked": false,
      "text": "第2位 Tuple (Item 1):0x3FC0 - 0x3FD7\nip_blkid指向真实的表记录数据\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "物理第2位 Tuple (Item 10):0x1EE8 - 0x1EFF\nip_blkid：0x0B ---- 11\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
